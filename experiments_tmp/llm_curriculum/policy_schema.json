{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Curriculum Policy",
  "description": "Training policy for RNA-OmniDistill relational masked diffusion. LLM acts as a policy compiler, not a structure predictor.",
  "type": "object",
  "required": ["family", "source", "regime", "mask_policy", "negative_policy", "sampling_policy", "confidence"],
  "additionalProperties": false,
  "properties": {
    "family": {"type": "string"},
    "source": {"type": "string"},
    "regime": {"type": "string", "enum": ["local_hairpin", "structured_short_rna", "long_range_rna", "mixed", "unknown"]},
    "mask_policy": {
      "type": "object",
      "required": ["mode", "mask_ratio", "span_len"],
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string", "enum": ["random", "span"]},
        "mask_ratio": {"type": "number", "minimum": 0.05, "maximum": 0.30},
        "span_len": {"type": "integer", "minimum": 1, "maximum": 12}
      }
    },
    "negative_policy": {
      "type": "object",
      "required": ["mode", "near_diagonal_weight", "long_range_weight"],
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string", "enum": ["random", "near_diagonal", "medium_long", "canonical_hard_negative"]},
        "near_diagonal_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "long_range_weight": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "sampling_policy": {
      "type": "object",
      "required": ["sampling_weight", "curriculum_stage"],
      "additionalProperties": false,
      "properties": {
        "sampling_weight": {"type": "number", "minimum": 0.5, "maximum": 2.0},
        "curriculum_stage": {"type": "integer", "minimum": 1, "maximum": 3}
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
